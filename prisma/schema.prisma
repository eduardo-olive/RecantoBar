generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url       = env("DATABASE_URL")
}

model Categoria {
  id        String    @id @default(cuid())
  nome      String    @unique
  produtos  Produto[]
}

model Produto {
  id            String   @id @default(cuid())
  nome          String
  precoVenda    Float
  precoCusto    Float
  estoque       Int
  estoqueMinimo Int
  estoqueSeguro Int
  categoriaId   String
  categoria     Categoria @relation(fields: [categoriaId], references: [id])
  requerPreparo Boolean  @default(false)
  perdas        Perda[]
  pedidoItens   PedidoItem[]
  createdAt     DateTime @default(now())
}

model Movimentacao {
  id           String   @id @default(cuid())
  data         DateTime @default(now())
  desc         String
  pagamento    String?
  tipo         String   // 'ENTRADA' ou 'SAIDA'
  valor        Float
  categoria    String   @default("VENDA") // VENDA, COMPRA, DESPESA, PERDA, SANGRIA, SUPRIMENTO
  subcategoria String?  // Para DESPESA: ALUGUEL, LUZ, AGUA, SALARIOS, etc.
  caixaId      Int?
  caixa        Caixa?   @relation(fields: [caixaId], references: [id])
  perda        Perda?
  conta        ContaPagarReceber?
  pedido       Pedido?        @relation("PedidoMovimentacao")
  comandaPgto  ComandaPagamento?
}

model Perda {
  id             String        @id @default(cuid())
  data           DateTime      @default(now())
  produtoId      String
  produto        Produto       @relation(fields: [produtoId], references: [id])
  qtd            Int
  motivo         String
  movimentacaoId String?       @unique
  movimentacao   Movimentacao? @relation(fields: [movimentacaoId], references: [id])
}

model Caixa {
  id              Int            @id @default(autoincrement())
  valor_inicial   Decimal        @db.Decimal(10, 2)
  valor_atual     Decimal        @db.Decimal(10, 2)
  data_abertura   DateTime       @default(now())
  data_fechamento DateTime?
  valor_fechamento Decimal?      @db.Decimal(10, 2)
  diferenca       Decimal?       @db.Decimal(10, 2)
  observacao      String?
  status          String         @default("aberto")
  movimentacoes   Movimentacao[]
}

model Usuario {
  id        String   @id @default(cuid())
  nome      String
  email     String   @unique
  senhaHash String
  perfilId  String
  perfil    Perfil   @relation(fields: [perfilId], references: [id])
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Perfil {
  id         String    @id @default(cuid())
  nome       String    @unique
  permissoes Json      // ["vendas","caixa","estoque","financeiro","relatorios","admin","usuarios"]
  usuarios   Usuario[]
  createdAt  DateTime  @default(now())
}

model Mesa {
  id         Int       @id @default(autoincrement())
  numero     Int       @unique
  nome       String?
  capacidade Int       @default(4)
  status     String    @default("LIVRE") // LIVRE, OCUPADA
  ativa      Boolean   @default(true)
  comandas   Comanda[]
  pedidos    Pedido[]
  createdAt  DateTime  @default(now())
}

model Comanda {
  id             String             @id @default(cuid())
  mesaId         Int
  mesa           Mesa               @relation(fields: [mesaId], references: [id])
  status         String             @default("ABERTA") // ABERTA, FECHADA, CANCELADA
  clienteNome    String?
  observacao     String?
  pedidos        Pedido[]
  pagamentos     ComandaPagamento[]
  dataAbertura   DateTime           @default(now())
  dataFechamento DateTime?
}

model Pedido {
  id              String        @id @default(cuid())
  mesaId          Int?
  mesa            Mesa?         @relation(fields: [mesaId], references: [id])
  comandaId       String?
  comanda         Comanda?      @relation(fields: [comandaId], references: [id])
  movimentacaoId  String?       @unique
  movimentacao    Movimentacao? @relation("PedidoMovimentacao", fields: [movimentacaoId], references: [id])
  metodoPagamento String?
  valorTotal      Float
  pago            Boolean       @default(false)
  itens           PedidoItem[]
  criadoEm        DateTime      @default(now())
}

model PedidoItem {
  id          String   @id @default(cuid())
  pedidoId    String
  pedido      Pedido   @relation(fields: [pedidoId], references: [id])
  produtoId   String
  produto     Produto  @relation(fields: [produtoId], references: [id])
  quantidade  Int
  precoUnit   Float
  subtotal    Float
  status      String   @default("ENTREGUE") // PENDENTE, PREPARANDO, PRONTO, ENTREGUE
  observacao  String?
  mesaNumero  Int?
  criadoEm    DateTime @default(now())
  atualizadoEm DateTime @updatedAt
}

model ComandaPagamento {
  id              String        @id @default(cuid())
  comandaId       String
  comanda         Comanda       @relation(fields: [comandaId], references: [id])
  valor           Float
  metodoPagamento String
  movimentacaoId  String?       @unique
  movimentacao    Movimentacao? @relation(fields: [movimentacaoId], references: [id])
  criadoEm        DateTime      @default(now())
}

model CategoriaDespesa {
  id        String   @id @default(cuid())
  nome      String   @unique
  createdAt DateTime @default(now())
}

model ContaPagarReceber {
  id             String        @id @default(cuid())
  tipo           String        // PAGAR ou RECEBER
  descricao      String
  valor          Float
  dataVencimento DateTime
  dataPagamento  DateTime?
  status         String        @default("PENDENTE") // PENDENTE, PAGO, CANCELADO
  categoria      String?       // ALUGUEL, FORNECEDOR, CLIENTE, etc.
  movimentacaoId String?       @unique
  movimentacao   Movimentacao? @relation(fields: [movimentacaoId], references: [id])
  createdAt      DateTime      @default(now())
}